{
  "name": "codegraph",
  "displayName": "codegraph",
  "description": "Graph representation of symbols",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "falkordb-explorer",
          "title": "FalkorDB",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "falkordb-explorer": [
        {
          "icon": "$(settings-gear)",
          "id": "falkordb.graph",
          "name": "Graph View",
          "type": "webview"
        },
        {
          "icon": "$(type-hierarchy)",
          "id": "falkordb.details",
          "name": "Node / Edge Details",
          "type": "webview"
        },
        {
          "icon": "$(list-selection)",
          "id": "falkordb.config",
          "name": "Connection & Config",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "FalkorDB",
      "properties": {
        "falkordb.connectionMode": {
          "type": "string",
          "enum": [
            "embedded",
            "remote"
          ],
          "default": "embedded",
          "description": "Whether to use the zero-config embedded FalkorDBLite or a remote instance"
        },
        "falkordb.host": {
          "type": "string",
          "default": "localhost",
          "description": "Host for remote FalkorDB connection"
        },
        "falkordb.port": {
          "type": "number",
          "default": 6379,
          "description": "Port for remote FalkorDB connection"
        },
        "falkordb.password": {
          "type": "string",
          "description": "Password for remote FalkorDB (stored securely)"
        },
        "falkordb.graphName": {
          "type": "string",
          "default": "default",
          "description": "Name of the graph to use/query"
        },
        "falkordb.dataPath": {
          "type": "string",
          "default": "${workspaceFolder}/.falkordb",
          "description": "Filesystem path for embedded FalkorDBLite persistence"
        }
      }
    },
    "commands": [
      {
        "command": "falkordb.helloWorld",
        "title": "FalkorDB: Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@falkordblite/linux-x64": "^8.2.3-falkordb.4.16.3",
    "falkordb": "^6.6.2",
    "falkordblite": "^0.2.0"
  }
}
